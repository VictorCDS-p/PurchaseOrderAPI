{
  "info": {
    "name": "PurchaseOrderAPI",
    "_postman_id": "final-collection-0002",
    "description": "Fluxo completo com aprovação e cancelamento",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5139" },
    { "key": "supplyId", "value": "" },
    { "key": "managerId", "value": "" },
    { "key": "directorId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "orderIdCancel", "value": "" }
  ],
  "item": [

    {
      "name": "1 - Criar Usuários",
      "item": [

        {
          "name": "Criar Supply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Supply User\",\n  \"email\": \"supply@test.com\",\n  \"role\": \"Supply\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.code === 200);",
                "let json = pm.response.json();",
                "pm.environment.set('supplyId', json.result.id);"
              ]
            }
          }]
        },

        {
          "name": "Criar Manager",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Manager User\",\n  \"email\": \"manager@test.com\",\n  \"role\": \"Manager\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.environment.set('managerId', json.result.id);"
              ]
            }
          }]
        },

        {
          "name": "Criar Director",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Director User\",\n  \"email\": \"director@test.com\",\n  \"role\": \"Director\"\n}"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.environment.set('directorId', json.result.id);"
              ]
            }
          }]
        }

      ]
    },

    {
      "name": "2 - Criar Pedido (Fluxo Normal)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{supplyId}},\n  \"items\": [\n    {\n      \"productName\": \"Notebook\",\n      \"quantity\": 2,\n      \"unitPrice\": 800\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/purchaseorders"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.environment.set('orderId', json.result.id);"
          ]
        }
      }]
    },

    {
      "name": "3 - Criar Pedido (Para Cancelar)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": {{supplyId}},\n  \"items\": [\n    {\n      \"productName\": \"Mouse\",\n      \"quantity\": 5,\n      \"unitPrice\": 50\n    }\n  ]\n}"
        },
        "url": "{{baseUrl}}/api/purchaseorders"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.environment.set('orderIdCancel', json.result.id);"
          ]
        }
      }]
    },

    {
      "name": "4 - Cancelar Pedido (Manager)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/cancel?userId={{managerId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Cancelado com sucesso', () => pm.response.code === 200);",
            "let json = pm.response.json();",
            "pm.test('Status Cancelled', () => pm.expect(json.result.status).to.eql('Cancelled'));"
          ]
        }
      }]
    },

    {
      "name": "5 - Tentar Aprovar Pedido Cancelado (Deve falhar)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/approve?userId={{supplyId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "pm.test('Não pode aprovar cancelado', () => pm.response.code >= 400);"
          ]
        }
      }]
    },

    {
      "name": "6 - Aprovar Supply",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{supplyId}}"
      }
    },

    {
      "name": "7 - Aprovar Manager",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{managerId}}"
      }
    },

    {
      "name": "8 - Aprovar Director",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{directorId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.test('Finalizado', () => pm.expect(json.result.status).to.eql('Completed'));"
          ]
        }
      }]
    },

    {
      "name": "9 - Histórico Pedido Normal",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/history"
      }
    },

    {
      "name": "10 - Histórico Pedido Cancelado",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/history"
      }
    }

  ]
}