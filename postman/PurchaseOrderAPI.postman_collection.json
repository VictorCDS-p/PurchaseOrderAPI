{
  "info": {
    "_postman_id": "84910376-bcfd-4456-95fc-0016e59aebe2",
    "name": "PurchaseOrderAPI",
    "description": "Fluxo completo com aprovação, revisão e cancelamento",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1 - Criar Usuários",
      "item": [
        {
          "name": "Criar Supply",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Supply User\", \"email\": \"supply@test.com\", \"role\": \"Supply\" }"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.environment.set('supplyId', json.result.id);"
              ]
            }
          }]
        },
        {
          "name": "Criar Manager",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Manager User\", \"email\": \"manager@test.com\", \"role\": \"Manager\" }"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.environment.set('managerId', json.result.id);"
              ]
            }
          }]
        },
        {
          "name": "Criar Director",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"name\": \"Director User\", \"email\": \"director@test.com\", \"role\": \"Director\" }"
            },
            "url": "{{baseUrl}}/api/users"
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "let json = pm.response.json();",
                "pm.environment.set('directorId', json.result.id);"
              ]
            }
          }]
        }
      ]
    },

    {
      "name": "2 - Criar Pedido (Fluxo Principal)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"userId\": {{supplyId}}, \"items\": [{ \"productName\": \"Notebook\", \"quantity\": 2, \"unitPrice\": 800 }] }"
        },
        "url": "{{baseUrl}}/api/purchaseorders"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.environment.set('orderId', json.result.id);"
          ]
        }
      }]
    },

    {
      "name": "3 - Aprovar Supply",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{supplyId}}"
      }
    },

    {
      "name": "4 - Solicitar Revisão (Manager)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/request-review?userId={{managerId}}"
      }
    },

    {
      "name": "5 - Reaprovar Supply (Após Revisão)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{supplyId}}"
      }
    },

    {
      "name": "6 - Aprovar Manager",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{managerId}}"
      }
    },

    {
      "name": "7 - Aprovar Director",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/approve?userId={{directorId}}"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.test('Pedido finalizado', () => pm.expect(json.result.status).to.eql('Completed'));"
          ]
        }
      }]
    },

    {
      "name": "8 - Ver Histórico (Fluxo Completo com Revisão)",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderId}}/history"
      }
    },

    {
      "name": "9 - Criar Pedido (Para Cancelar)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{ \"userId\": {{supplyId}}, \"items\": [{ \"productName\": \"Mouse\", \"quantity\": 5, \"unitPrice\": 50 }] }"
        },
        "url": "{{baseUrl}}/api/purchaseorders"
      },
      "event": [{
        "listen": "test",
        "script": {
          "exec": [
            "let json = pm.response.json();",
            "pm.environment.set('orderIdCancel', json.result.id);"
          ]
        }
      }]
    },

    {
      "name": "10 - Cancelar Pedido",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/cancel?userId={{managerId}}"
      }
    },

    {
      "name": "11 - Tentar Aprovar Cancelado (Erro esperado)",
      "request": {
        "method": "PATCH",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/approve?userId={{supplyId}}"
      }
    },

    {
      "name": "12 - Histórico Pedido Cancelado",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/purchaseorders/{{orderIdCancel}}/history"
      }
    }
  ],

  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5139" },
    { "key": "supplyId", "value": "" },
    { "key": "managerId", "value": "" },
    { "key": "directorId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "orderIdCancel", "value": "" }
  ]
}